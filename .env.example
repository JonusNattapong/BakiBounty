# BakiBounty Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git

# AI Analysis - Choose one provider
# --------------------------------

# Option 1: Kilo Code (has free models: Grok Code Fast 1, MiniMax M2.5)
BAKIBOUNTY_AI_KEY=your_kilo_jwt_token_here

# Option 2: MiniMax Direct (Free tier available)
# BAKIBOUNTY_AI_KEY=your_minimax_api_key
# Set provider: minimax in config.yaml

# Option 3: Groq (Free tier - Llama 3.1 70B)
# BAKIBOUNTY_AI_KEY=your_groq_api_key
# Set provider: groq in config.yaml

# Option 4: Together AI ($5 free credit)
# BAKIBOUNTY_AI_KEY=your_together_api_key
# Set provider: together in config.yaml

# Option 5: DeepSeek (Very cheap)
# BAKIBOUNTY_AI_KEY=your_deepseek_api_key
# Set provider: deepseek in config.yaml

# Notifications - Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Notifications - Discord
DISCORD_WEBHOOK_URL=your_webhook_url
